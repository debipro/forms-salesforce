# =====================================================================
# debi-forms-salesforce — variables de entorno
#
# Copiá este archivo a `.env` para desarrollo local, o pegá estas 5
# variables en Vercel → Project Settings → Environment Variables.
#
# Las 5 son OBLIGATORIAS. No hay variables opcionales en este template.
# =====================================================================

# ---------- Salesforce (obtené las 3 del asistente de Debi) ----------
# Pedile a Debi la URL del asistente de onboarding. Te logueás con
# Salesforce y la pantalla final te muestra los 3 valores siguientes
# listos para copiar.

# URL del instance de tu organización Salesforce.
# Ej.: https://miorg.my.salesforce.com
SF_INSTANCE_URL=

# Refresh token de larga duración emitido por la Connected App de Debi.
SF_REFRESH_TOKEN=

# Login host de Salesforce. El asistente te da el correcto:
#   - https://login.salesforce.com   (producción)
#   - https://test.salesforce.com    (sandbox)
SF_LOGIN_URL=

# ---------- Debi (panel de desarrolladores) ----------
# Andá a https://debi.pro/dashboard/developers y copiá los 2 valores.

# Clave pública (pk_live_*) — se usa en el navegador para tokenizar
# tarjetas y CBUs. Es seguro exponerla.
DEBI_PUBLIC_KEY=

# Clave secreta (sk_live_*) — solo se usa del lado del servidor.
# Hoy ningún flujo la consume, pero se exige para que los flujos
# futuros que llamen a Debi desde el backend ya tengan acceso sin
# pedirte agregar otra variable.
DEBI_SECRET_KEY=
